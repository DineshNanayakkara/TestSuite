# =============================================================================
# Dynamics 365 Playwright test suite — configuration
# Copy to ".env" and fill in. NEVER commit a filled-in .env (see .gitignore).
# Nothing here is assumed by the code; every value is read from the environment.
# =============================================================================

# --- Target environment -------------------------------------------------------
# Base org URL, no trailing slash. The region segment (.crm / .crm4 / .crm11 ...)
# is part of YOUR org URL — do not guess it, copy it from your environment.
DATAVERSE_URL=https://yourorg.crm.dynamics.com

# Web API version segment. Default v9.2 (current). Override only if needed.
DATAVERSE_API_VERSION=v9.2

# The model-driven APP a form is opened within. Find the GUID in Power Apps maker
# portal > Apps > (your app) > Details > App ID. Optional but recommended: if
# omitted, D365 opens the form in the user's default app for that table.
DATAVERSE_APP_ID=

# --- The solution to test (the only "what to test" input) ---------------------
# Unique name (NOT the friendly/display name). Maker portal > Solutions > column
# "Name". The suite discovers every entity + form in this solution.
SOLUTION_UNIQUE_NAME=

# --- Metadata API auth: Microsoft Entra ID service principal (client creds) ---
# Used by `npm run discover` to read solution/entity/form metadata via Web API.
# Requires an Application User in Dataverse bound to this app registration.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- UI auth: how the browser logs in to run the form tests -------------------
# A service principal CANNOT sign in to the model-driven web UI, so the browser
# session uses a real user. Two supported modes:
#
#   storageState  (DEFAULT, recommended): reuse a saved signed-in session.
#                 Generate it once with: `npx playwright codegen <DATAVERSE_URL>`
#                 then save storage state, or let auth.setup.ts create it (below).
#   credentials   best-effort automated login with the username/password below.
#                 Works only for accounts WITHOUT MFA / Conditional Access prompts
#                 (e.g. a dedicated test account). Otherwise use storageState.
UI_AUTH_MODE=storageState
UI_STORAGE_STATE=.auth/user.json
DATAVERSE_USERNAME=
DATAVERSE_PASSWORD=

# --- What to test (all optional; safe defaults) -------------------------------
# Comma-separated systemform.type values to include. 2=Main (default),
# 7=Quick Create, 6=Quick View, 11=Card, 0=Dashboard, 12=Main-Interactive.
FORM_TYPES=2

# Only test Active forms (formactivationstate=1). true (default) | false
ACTIVE_ONLY=true

# Optional allow/deny lists of entity logical names (comma-separated) applied on
# TOP of solution discovery. Empty allow = all discovered entities.
ENTITY_ALLOW=
ENTITY_DENY=

# Write a record to prove the form round-trips (create -> verify -> delete).
# WARNING: this writes (and deletes) data in the target environment. false=default.
ENABLE_CRUD_ROUNDTRIP=false

# Treat unhandled browser console errors during a form interaction as a failure
# (true) or a warning (false, default).
CONSOLE_ERROR_FATAL=false

# Where discovery writes the manifest the tests consume.
MANIFEST_PATH=artifacts/manifest.json
